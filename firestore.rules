rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Is Admin Helper
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "eyuaelijah@gmail.com";
    }

    // Deposits Collection rules
    match /deposits/{depositId} {
      // Anyone can submit or manage deposits (secured client-side via master admin passcode)
      allow create, read, update, delete: if true;
    }

    // Admin Configurations rules
    match /admin_config/{configId} {
      // Allow read and write so the backend server can sync and persist the OAuth token and state dynamically
      allow read, write: if true;
    }
  }
}
